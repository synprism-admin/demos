/*# sourceURL=global-styles-inline-css */</style><style id="lw-spin-wheel-style-inline-css">.lw-language-grid{display:grid!important;grid-template-columns:repeat(3,minmax(0,1fr))!important;gap:10px!important;align-items:start!important;grid-auto-rows:54px!important;}
.lw-language-item{display:flex!important;align-items:center!important;justify-content:center!important;height:54px!important;min-height:54px!important;max-height:54px!important;padding:6px 10px!important;line-height:1.15!important;white-space:normal!important;overflow:hidden!important;box-sizing:border-box!important;}
.lw-language-item br{display:none!important;}
.lw-wheel-link-card.is-hidden{display:none!important;}
.lw-wheel-links{position:relative!important;padding-bottom:54px!important;}
.lw-wheel-links-more{position:absolute!important;right:10px!important;bottom:10px!important;display:flex!important;align-items:center!important;justify-content:center!important;width:35px!important;height:35px!important;padding:0!important;border:1px solid #d8dde1!important;border-radius:50%!important;background:#fff!important;font-size:0!important;line-height:1!important;cursor:pointer!important;box-shadow:0 6px 18px rgba(0,0,0,.18)!important;}
.lw-wheel-links-more span{display:block!important;width:12px!important;height:12px!important;border-right:2px solid #111!important;border-bottom:2px solid #111!important;transform:rotate(45deg)!important;margin-top:-5px!important;}
.entry-content.is-fullscreen,.entry-content:fullscreen{width:100vw!important;height:100vh!important;max-width:none!important;margin:0!important;padding:30px!important;overflow-y:auto!important;overflow-x:hidden!important;box-sizing:border-box!important;background:#f3f3f3!important;}
.entry-content.is-fullscreen .lw-spin-wrapper,.entry-content:fullscreen .lw-spin-wrapper{width:100%!important;max-width:1280px!important;margin:0 auto!important;padding:0!important;}
.entry-content.is-fullscreen .lw-spin-box,.entry-content:fullscreen .lw-spin-box{width:auto!important;height:auto!important;min-height:0!important;max-width:1280px!important;margin:0 auto 24px!important;padding:28px 30px!important;border-radius:8px!important;overflow:visible!important;}
.entry-content.is-fullscreen .lw-extra-boxes,.entry-content:fullscreen .lw-extra-boxes,.entry-content.is-fullscreen .preset-text,.entry-content:fullscreen .preset-text{display:block!important;max-width:1280px!important;margin:24px auto!important;visibility:visible!important;opacity:1!important;}
.entry-content.is-fullscreen .lw-wheel-links,.entry-content:fullscreen .lw-wheel-links,.entry-content.is-fullscreen .lw-wheel-text,.entry-content:fullscreen .lw-wheel-text,.entry-content.is-fullscreen .preset-text,.entry-content:fullscreen .preset-text{box-shadow:0 8px 26px rgba(0,0,0,.18)!important;}
.entry-content.is-fullscreen .lw-custom-block,.entry-content:fullscreen .lw-custom-block{display:none!important;}
body.lw-spin-dark-page .entry-content.is-fullscreen,.entry-content.is-fullscreen .lw-spin-wrapper.is-dark,.entry-content:fullscreen .lw-spin-wrapper.is-dark{background:#260304!important;}

/*# sourceURL=lw-spin-wheel-style-inline-css */</style><meta name="generator" content="Site Kit by Google 1.181.0" /><meta name="google-adsense-platform-account" content="ca-host-pub-2644536267352236"><meta name="google-adsense-platform-domain" content="sitekit.withgoogle.com"><link rel="icon" href="https://logos-world.net/wp-content/uploads/2020/03/logos-world-icon-1.png" sizes="32x32" /><link rel="icon" href="https://logos-world.net/wp-content/uploads/2020/03/logos-world-icon-1.png" sizes="192x192" /><link rel="apple-touch-icon" href="https://logos-world.net/wp-content/uploads/2020/03/logos-world-icon-1.png" /><meta name="msapplication-TileImage" content="https://logos-world.net/wp-content/uploads/2020/03/logos-world-icon-1.png" /><style id="wp-custom-css">div.ast-mobile-popup-content {
	display: block!important;
}
.widget {
    margin: 0 0 0 0;
}
span:focus { outline: none; }


.ast-site-identity {
    padding: 0.4em 0; 
}

#primary {
    margin: 1em 0;
}

.ast-single-post-order h1 {

	margin-bottom: 0px;
}

span.published, span.updated, span.cat-links a, span.sep {
	/*text-transform: uppercase;*/
	font-size: 16px;
}

.main-header-menu .menu-item, .ast-header-break-point .main-navigation .stack-on-mobile li {
	    width: calc(49% - 6px);
    float: left;
    margin: 3px 3px;
    border-bottom: 0px solid transparent;
}

a.cat-post-title {
	color: #282828;
}
#category-posts-2-internal .cat-post-current .cat-post-title {
    font-weight: normal;
    text-transform: none;
}

.ast-builder-menu-mobile .main-navigation ul .menu-item .menu-link, .ast-builder-menu-mobile .main-navigation ul .menu-item .menu-link {
    border: 1px solid rgba(255,255,255,.08)!important;
	padding: 0.4em 0em 0.2em 0.5em;
