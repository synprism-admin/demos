    filter: drop-shadow(0px 4px 4px rgba(0, 0, 0, 0.25));
}
.box_color_custom .wrap {
    max-width: 100%;
    margin: 0 auto;
    align-items: center;
    justify-content: center;
    color: #000;
    padding: 40px 60px;
    position: relative;
}
.box_color_custom .wrap .half.w40 {
    width: 40%;
    float: left;
    padding: 0;
    text-align: center;
}
