let colors=colorSchemes[activeColorScheme].slice();const closeModalBtn=root.querySelector('.lw-win-close');const spinAgainBtn=root.querySelector('.lw-spin-again');function hexToRgb(hex){const clean=String(hex).replace('#','');return{r:parseInt(clean.substring(0,2),16),g:parseInt(clean.substring(2,4),16),b:parseInt(clean.substring(4,6),16)}}
function rgbToHex(r,g,b){return'#'+[r,g,b].map(function(value){const hex=Math.max(0,Math.min(255,Math.round(value))).toString(16);return hex.length===1?'0'+hex:hex}).join('')}
function shadeColor(hex,amount){const rgb=hexToRgb(hex);return rgbToHex(rgb.r+(amount>0?(255-rgb.r)*amount:rgb.r*amount),rgb.g+(amount>0?(255-rgb.g)*amount:rgb.g*amount),rgb.b+(amount>0?(255-rgb.b)*amount:rgb.b*amount))}
function makeSectorGradient(baseColor,midAngle){const innerX=280+Math.cos(midAngle)*75;const innerY=280+Math.sin(midAngle)*75;const outerX=280+Math.cos(midAngle)*275;const outerY=280+Math.sin(midAngle)*275;const gradient=ctx.createLinearGradient(innerX,innerY,outerX,outerY);gradient.addColorStop(0,shadeColor(baseColor,0.24));gradient.addColorStop(0.48,baseColor);gradient.addColorStop(1,shadeColor(baseColor,-0.14));return gradient}
let angle=0;let spinning=!1;let tickAudio=null;let lastTickIndex=-1;let lastTickTime=0;let applauseAudio=null;if(typeof lwSpinWheelData!=='undefined'&&lwSpinWheelData.tickUrl){tickAudio=new Audio(lwSpinWheelData.tickUrl);tickAudio.volume=0.35}
if(typeof lwSpinWheelData!=='undefined'&&lwSpinWheelData.applauseUrl){applauseAudio=new Audio(lwSpinWheelData.applauseUrl);applauseAudio.volume=0.55}
function updateSoundIcon(){if(!soundBtn){return}
soundBtn.textContent=soundEnabled?'🔊':'🔇'}
const resultsStorageKey='lw_spin_results_'+window.location.pathname;let results=[];try{results=JSON.parse(sessionStorage.getItem(resultsStorageKey)||'[]')}catch(e){results=[]}
function saveResults(){sessionStorage.setItem(resultsStorageKey,JSON.stringify(results))}
let cachedEntries=[];function setWheelRotation(value){canvas.style.transform='rotate('+value+'rad)'}
let idleSpin=!0;let idleLastTime=0;let idleLastTickIndex=-1;function idleFrame(now){if(idleSpin&&!spinning&&!document.hidden){const delta=idleLastTime?Math.min(now-idleLastTime,64):16;const entries=cachedEntries.length?cachedEntries:getEntries();angle+=delta*0.0004;setWheelRotation(angle);const tickIndex=getSectorIndex(entries);if(tickIndex!==idleLastTickIndex){idleLastTickIndex=tickIndex;updatePointerColor(entries)}}
idleLastTime=now;requestAnimationFrame(idleFrame)}
function enforceLineLimit(showWarning){let lines=entriesBox.value.split(/\r?\n/);if(lines.length>maxLines){lines=lines.slice(0,maxLines);entriesBox.value=lines.join('\n')}
let changed=!1;const cleaned=lines.map(function(line){if(line.length>maxLineLength){changed=!0;return line.substring(0,maxLineLength)}
return line});if(changed){entriesBox.value=cleaned.join('\n')}
if(limitWarning){limitWarning.textContent=limitText;limitWarning.classList.add('is-visible')}}
function getEntries(){enforceLineLimit(!1);return entriesBox.value.split(/\r?\n/).map(function(item){return item.trim()}).filter(Boolean)}
function setEntries(items){entriesBox.value=items.join('\n');draw()}
function normalize(value){return((value%(Math.PI*2))+Math.PI*2)%(Math.PI*2)}
function getSectorIndex(entries){if(!entries.length){return 0}
const normalizedAngle=normalize(angle);const pointerWorldAngle=0;const wheelAngle=normalize(pointerWorldAngle-normalizedAngle);const slice=Math.PI*2/entries.length;return Math.floor(wheelAngle/slice)%entries.length}
function getSectorColor(entries){const index=getSectorIndex(entries);return colors[index%colors.length]}
function updatePointerColor(entries){area.style.setProperty('--lw-pointer-color',getSectorColor(entries))}
function splitLongWord(word,maxChars){const parts=[];let remaining=String(word||'');while(remaining.length>maxChars){parts.push(remaining.slice(0,maxChars));remaining=remaining.slice(maxChars)}
if(remaining){parts.push(remaining)}
return parts}
function wrapTextForSector(text,maxChars){const value=String(text||'').trim();if(!value){return['']}
const words=value.replace(/'/g,'’').split(/\s+/);const lines=[];words.forEach(function(word){if(word.length>maxChars){splitLongWord(word,maxChars).forEach(function(part){lines.push(part)});return}
if(!lines.length){lines.push(word);return}
const lastIndex=lines.length-1;const candidate=lines[lastIndex]+' '+word;if(candidate.length<=maxChars){lines[lastIndex]=candidate}else{lines.push(word)}});return lines}
function drawTextCircular(text,midAngle,radius,slice){const cleanText=String(text||'').trim();const sectorCount=Math.round((Math.PI*2)/slice);const sliceWidth=Math.max(95,radius*slice*0.72);let fontSize=30;if(sectorCount>10){fontSize=24}
if(sectorCount>14){fontSize=20}
if(sectorCount>18){fontSize=17}
if(sectorCount>24){fontSize=14}
if(cleanText.length>10){fontSize=Math.min(fontSize,22)}
if(cleanText.length>14){fontSize=Math.min(fontSize,19)}
if(cleanText.length>22){fontSize=Math.min(fontSize,16)}
if(cleanText.length>32){fontSize=Math.min(fontSize,13)}
function getMaxChars(size){let value=Math.max(7,Math.floor(sliceWidth/(size*0.48)));if(sectorCount<12){value=Math.min(value,13)}else if(sectorCount<18){value=Math.min(value,14)}else if(sectorCount<24){value=Math.min(value,13)}else{value=Math.min(value,12)}
return value}
let maxChars=getMaxChars(fontSize);let lines=wrapTextForSector(cleanText,maxChars);while(lines.length>3&&fontSize>12){fontSize-=1;maxChars=getMaxChars(fontSize);lines=wrapTextForSector(cleanText,maxChars)}
if(lines.length>3){lines=lines.slice(0,3)}
const lineHeight=fontSize*1.08;ctx.save();ctx.translate(280,280);ctx.rotate(midAngle);ctx.textAlign='center';ctx.textBaseline='middle';ctx.font='700 '+fontSize+'px "Segoe UI Emoji","Apple Color Emoji","Noto Color Emoji",Arial,sans-serif';ctx.lineWidth=Math.max(2,Math.floor(fontSize/7));ctx.strokeStyle='rgba(0,0,0,.62)';ctx.fillStyle='#fff';lines.forEach(function(line,index){const y=(index-(lines.length-1)/2)*lineHeight;ctx.strokeText(line,radius,y);ctx.fillText(line,radius,y)});ctx.restore()}
function draw(){const entries=getEntries();cachedEntries=entries;const count=entries.length||1;const slice=Math.PI*2/count;countBox.textContent=entries.length;ctx.clearRect(0,0,560,560);for(let i=0;i<count;i++){const start=i*slice;const end=start+slice;ctx.beginPath();ctx.moveTo(280,280);ctx.arc(280,280,275,start,end);ctx.closePath();const label=entries[i]||'';const wheelLabel=label.replace(/\p{Extended_Pictographic}/gu,'').trim();const mid=start+slice/2;const baseColor=colors[i%colors.length];ctx.fillStyle=makeSectorGradient(baseColor,mid);ctx.fill();ctx.save();ctx.globalAlpha=0.16;ctx.strokeStyle='#ffffff';ctx.lineWidth=1;ctx.stroke();ctx.restore();let textRadius=200;if(String(label).length>14){textRadius=205}
if(String(label).length>24){textRadius=190}
if(String(label).length>34){textRadius=175}
drawTextCircular(wheelLabel||label,mid,textRadius,slice)}
setWheelRotation(angle);updatePointerColor(entries)}
function pickWinner(entries){return entries[getSectorIndex(entries)]}
function renderResults(){if(!results.length){resultsList.innerHTML='';return}
resultsList.innerHTML=results.map(function(item){return'<div>'+escapeHtml(item)+'</div>'}).join('')}
function escapeHtml(value){return String(value).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;')}
function updateGlobalTotal(){if(typeof lwSpinWheelData==='undefined'){return}
const body=new URLSearchParams();body.append('action','lw_spin_wheel_count');body.append('nonce',lwSpinWheelData.nonce);fetch(lwSpinWheelData.ajaxUrl,{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:body.toString()}).then(function(response){return response.json()}).then(function(data){if(data&&data.success&&data.data&&typeof data.data.total!=='undefined'){totalBox.textContent=data.data.total}})}
function renderColorSchemes(){colorGrid.innerHTML='';colorSchemes.forEach(function(scheme,index){const item=document.createElement('button');item.type='button';item.className='lw-color-scheme';if(index===activeColorScheme){item.classList.add('is-active')}
item.innerHTML=scheme.map(function(color){return'<span style="background:'+color+'"></span>'}).join('');item.addEventListener('click',function(){activeColorScheme=index;colors=scheme.slice();localStorage.setItem(colorStorageKey,String(activeColorScheme));renderColorSchemes();draw()});colorGrid.appendChild(item)})}
function openColorModal(){renderColorSchemes();colorModal.classList.add('is-open');colorModal.setAttribute('aria-hidden','false')}
function closeColorModal(){colorModal.classList.remove('is-open');colorModal.setAttribute('aria-hidden','true')}
function openLanguageModal(){languageModal.classList.add('is-open');languageModal.setAttribute('aria-hidden','false')}
function closeLanguageModal(){languageModal.classList.remove('is-open');languageModal.setAttribute('aria-hidden','true')}
function openFavoriteModal(){favoriteModal.classList.add('is-open');favoriteModal.setAttribute('aria-hidden','false')}
function closeFavoriteModal(){favoriteModal.classList.remove('is-open');favoriteModal.setAttribute('aria-hidden','true')}
function openModal(value,color){winValue.textContent=value;winBox.style.setProperty('--lw-win-color',color);modal.classList.add('is-open');modal.setAttribute('aria-hidden','false');if(soundEnabled&&applauseAudio){try{applauseAudio.currentTime=0;applauseAudio.play()}catch(e){}}
launchConfetti()}
if(languageBtn){languageBtn.addEventListener('click',openLanguageModal)}
if(languageCloseBtn){languageCloseBtn.addEventListener('click',closeLanguageModal)}
if(languageModal){languageModal.addEventListener('click',function(event){if(event.target===languageModal){closeLanguageModal()}})}
function closeModal(){modal.classList.remove('is-open');modal.setAttribute('aria-hidden','true')}
function launchConfetti(){const canvas=document.createElement('canvas');const ctxConfetti=canvas.getContext('2d');const pieces=[];const colorsConfetti=['#ff111b','#00b83f','#0867c1','#ffd400','#ff7500','#8500c7'];canvas.style.position='fixed';canvas.style.left='0';canvas.style.top='0';canvas.style.width='100%';canvas.style.height='100%';canvas.style.pointerEvents='none';canvas.style.zIndex='1000000';document.body.appendChild(canvas);function resize(){canvas.width=window.innerWidth;canvas.height=window.innerHeight}
resize();for(let i=0;i<260;i++){const side=i<130?'left':'right';const startY=canvas.height*(0.22+Math.random()*0.46);pieces.push({x:side==='left'?Math.random()*170-60:canvas.width-Math.random()*170+60,y:startY,vx:side==='left'?Math.random()*11+4:-(Math.random()*11+4),vy:-(Math.random()*11+2),size:Math.random()*9+4,color:colorsConfetti[Math.floor(Math.random()*colorsConfetti.length)],gravity:0.20+Math.random()*0.08,rotation:Math.random()*360,rotationSpeed:Math.random()*16-8,life:150+Math.floor(Math.random()*50)})}
function frame(){ctxConfetti.clearRect(0,0,canvas.width,canvas.height);pieces.forEach(function(p){p.x+=p.vx;p.y+=p.vy;p.vy+=p.gravity;p.rotation+=p.rotationSpeed;p.life-=1;ctxConfetti.save();ctxConfetti.translate(p.x,p.y);ctxConfetti.rotate(p.rotation*Math.PI/180);ctxConfetti.fillStyle=p.color;ctxConfetti.fillRect(-p.size/2,-p.size/2,p.size,p.size*0.55);ctxConfetti.restore()});if(pieces.some(function(p){return p.life>0&&p.y<canvas.height+40})){requestAnimationFrame(frame)}else{canvas.remove()}}
frame()}
function setPanelButtonsDisabled(disabled){if(shuffleBtn){shuffleBtn.disabled=disabled;shuffleBtn.classList.toggle('is-disabled',disabled)}
if(sortBtn){sortBtn.disabled=disabled;sortBtn.classList.toggle('is-disabled',disabled)}[colorBtn,languageBtn,favoriteBtn,themeBtn,fullscreenBtn,clearParticipantsBtn].forEach(function(btn){if(btn){btn.disabled=disabled;btn.classList.toggle('is-disabled',disabled)}})}
function spin(){if(spinning){return}
const entries=getEntries();if(!entries.length){resultBox.textContent='Add entries';return}
spinning=!0;area.classList.add('is-spinning');resultBox.textContent='';entriesBox.disabled=!0;setPanelButtonsDisabled(!0);const startAngle=angle;const turns=5.4+Math.random()*0.9;const randomStop=Math.random()*Math.PI*2;const target=startAngle+Math.PI*2*turns+randomStop;const duration=9000+Math.random()*700;const startTime=performance.now();lastTickIndex=getSectorIndex(entries);lastTickTime=0;setWheelRotation(startAngle);function wheelEase(t){return 1-Math.pow(1-t,4)}
function finishSpin(){angle=target;setWheelRotation(angle);updatePointerColor(entries);spinning=!1;setPanelButtonsDisabled(!1);entriesBox.disabled=!1;area.classList.remove('is-spinning');const winner=pickWinner(entries);const color=getSectorColor(entries);resultBox.textContent=winner;results.unshift(winner);saveResults();renderResults();updateGlobalTotal();openModal(winner,color)}
function frame(now){const progress=Math.min((now-startTime)/duration,1);const eased=wheelEase(progress);angle=startAngle+(target-startAngle)*eased;setWheelRotation(angle);const tickIndex=getSectorIndex(entries);if(tickIndex!==lastTickIndex){lastTickIndex=tickIndex;updatePointerColor(entries);if(soundEnabled&&tickAudio&&now-lastTickTime>42){lastTickTime=now;try{tickAudio.currentTime=0;tickAudio.play()}catch(e){}}}
if(progress<1){requestAnimationFrame(frame)}else{finishSpin()}}
requestAnimationFrame(frame)}
let drawTimer=null;entriesBox.addEventListener('input',function(){enforceLineLimit(!0);clearTimeout(drawTimer);drawTimer=setTimeout(function(){draw()},120)});entriesBox.addEventListener('paste',function(){setTimeout(function(){enforceLineLimit(!0);draw()},0)});area.addEventListener('click',function(event){if(event.target.closest('.lw-spin-btn')||event.target===area||event.target===canvas||event.target.classList.contains('lw-wheel-center')){spin()}});spinBtn.addEventListener('click',function(event){event.preventDefault();event.stopPropagation();spin()});closeModalBtn.addEventListener('click',closeModal);modal.addEventListener('click',function(event){if(event.target===modal){closeModal()}});spinAgainBtn.addEventListener('click',function(){closeModal();spin()});if(clearResultsBtn){clearResultsBtn.addEventListener('click',function(){results=[];sessionStorage.removeItem(resultsStorageKey);renderResults()})}
