renderResults();draw()})}
if(colorBtn){colorBtn.addEventListener('click',openColorModal)}
if(colorCloseBtn){colorCloseBtn.addEventListener('click',closeColorModal)}
if(colorModal){colorModal.addEventListener('click',function(event){if(event.target===colorModal){closeColorModal()}})}
function getFullscreenTarget(){if(wrapper){const entryContent=wrapper.closest('.entry-content');if(entryContent){return entryContent}
const article=wrapper.closest('article');if(article){return article}
return wrapper}
return root}
function toggleFullscreenBox(){const fullscreenTarget=getFullscreenTarget();if(!document.fullscreenElement){fullscreenTarget.classList.add('is-fullscreen');root.classList.add('is-fullscreen');if(wrapper){wrapper.classList.add('is-fullscreen')}
fullscreenTarget.requestFullscreen().then(function(){draw()}).catch(function(){draw()})}else{document.exitFullscreen()}}
document.addEventListener('fullscreenchange',function(){const fullscreenTarget=getFullscreenTarget();const isActive=document.fullscreenElement===fullscreenTarget;fullscreenTarget.classList.toggle('is-fullscreen',isActive);root.classList.toggle('is-fullscreen',isActive);if(wrapper){wrapper.classList.toggle('is-fullscreen',isActive)}
draw()});if(fullscreenBtn){fullscreenBtn.addEventListener('click',function(){toggleFullscreenBox()})}
if(themeBtn){themeBtn.addEventListener('click',function(){root.classList.toggle('is-dark');if(wrapper){wrapper.classList.toggle('is-dark',root.classList.contains('is-dark'))}
