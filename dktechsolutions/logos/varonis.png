margin-top: 40px; }





blockquote {
    position: relative;
    margin: 22px 0 34px;
    padding: 26px 28px 24px 48px !important;
    background: linear-gradient(to bottom, #fbfbfb, #f3f3f3);
    border: 1px solid rgba(0,0,0,.035);
    border-radius: 34px;
    color: #000;
    box-sizing: border-box;
    box-shadow:
        0 2px 5px rgba(0,0,0,.035);
}

blockquote::before {
    content: "”";
    position: absolute;
    left: 17px;
    top: 12px;
    font-family: Georgia, serif;
    font-size: 34px;
    line-height: 1;
    font-weight: 700;
    color: #000;
}

blockquote::after {
    content: "";
    position: absolute;
    left: 58px;
    bottom: -10px;
    width: 24px;
    height: 24px;
    background: #f3f3f3;
    border-right: 1px solid rgba(0,0,0,.035);
    border-bottom: 1px solid rgba(0,0,0,.035);
    border-radius: 0 0 5px 0;
    transform: rotate(45deg);
    box-shadow: 2px 2px 4px rgba(0,0,0,.025);
}

blockquote p {
    margin: 0 0 12px 0;
}

blockquote p:last-child {
    margin-bottom: 0;
}

blockquote strong {
    display: block;
    margin-bottom: 12px;
    font-style: normal;
    font-weight: 700;
}

blockquote p:not(:first-child) {
    font-style: italic;
    line-height: 1.7;
}

@media (max-width: 767px) {
    blockquote {
        margin: 18px 0 30px;
        padding: 22px 20px 20px 42px !important;
        border-radius: 26px;
    }

    blockquote::before {
        left: 14px;
        top: 12px;
        font-size: 30px;
    }

    blockquote::after {
        left: 42px;
        bottom: -9px;
        width: 22px;
        height: 22px;
    }

    blockquote p:not(:first-child) {
        line-height: 1.55;
    }
}

.infobox {
    margin: 22px 0 0;
    padding: 0;
    background: transparent;
    border: 0;
}

.infobox_firs {
    margin: 0;
    padding: 10px 18px;
    background: linear-gradient(to bottom, #fbfbfb, #ededed);
    border: 1px solid rgba(0,0,0,.04);
    border-bottom: 0;
    border-radius: 34px 34px 0 0;
    box-sizing: border-box;
    text-align: center;
    box-shadow: 0 1px 4px rgba(0,0,0,.025);
}

.infobox_firs .infobox-title {
    margin: 0;
    padding: 0;
    font-family: Anton, Arial, sans-serif;
    font-size: 18px;
    line-height: 1.25;
    font-weight: 400;
    color: #000;
}

.previu {
    margin: 0 0 24px;
    padding: 18px 22px 22px;
    background: linear-gradient(to bottom, #f7f7f7, #efefef);
    border: 1px solid rgba(0,0,0,.04);
    border-top: 0;
    border-radius: 0 0 34px 34px;
    box-sizing: border-box;
    color: #000;
    box-shadow: 0 2px 5px rgba(0,0,0,.03);
}

.previu p {
    margin: 0 0 18px;
    font-size: 16px;

}

.previu p:last-child {
    margin-bottom: 0;
}

.previu > div {
    margin: 16px auto !important;
}

@media (max-width: 767px) {
    .infobox {
        margin: 18px 0 0;
    }

    .infobox_firs {
        padding: 9px 14px;
        border-radius: 24px 24px 0 0;
    }

    .infobox_firs h3 {
        font-size: 16px;
        line-height: 1.25;
    }

    .previu {
        margin: 0 0 22px;
        padding: 15px 16px 18px;
        border-radius: 0 0 24px 24px;
    }

    .previu p {
        margin: 0 0 15px;
        line-height: 1.6;
    }
}

.rpwwt-post-date {
    display: block;
    margin-top: 4px;
    color: #444 !important;
    font-size: 13px;
    line-height: 1.3;
}


/******* меню******/
/* Astra mobile popup menu */
.ast-mobile-popup-drawer.active .ast-mobile-popup-inner,
.ast-mobile-popup-drawer .ast-mobile-popup-inner {
    width: min(88vw, 360px) !important;
    max-width: 360px !important;
    background: #1d1d1d !important;
    box-shadow: 8px 0 28px rgba(0,0,0,.34) !important;
    overflow-y: auto !important;
    scrollbar-width: thin;
    scrollbar-color: #777 #1d1d1d;
}

/* Header with close button */
.ast-mobile-popup-drawer .ast-mobile-popup-header {
    min-height: 70px !important;
    padding: 14px 14px 8px !important;
    background: #1d1d1d !important;
    box-sizing: border-box !important;
}

/* Close button */
.ast-mobile-popup-drawer .menu-toggle-close {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 42px !important;
    height: 42px !important;
    margin-left: auto !important;
    padding: 0 !important;
    border-radius: 50% !important;
    background: rgba(255,255,255,.06) !important;
    color: #fff !important;
    border: 1px solid rgba(255,255,255,.12) !important;
    box-sizing: border-box !important;
}

.ast-mobile-popup-drawer .menu-toggle-close svg {
    width: 26px !important;
    height: 26px !important;
}

.ast-mobile-popup-drawer .menu-toggle-close:hover {
    background: rgba(164,10,14,.85) !important;
    border-color: rgba(164,10,14,.9) !important;
}

/* Popup content */
.ast-mobile-popup-drawer .ast-mobile-popup-content {
    display: block !important;
    padding: 8px 10px 22px !important;
    background: #1d1d1d !important;
    box-sizing: border-box !important;
}

/* Remove Astra inner spacing */
.ast-mobile-popup-drawer .ast-builder-menu-mobile,
.ast-mobile-popup-drawer .ast-main-header-bar-alignment,
.ast-mobile-popup-drawer .main-header-bar-navigation,
.ast-mobile-popup-drawer .site-navigation,
.ast-mobile-popup-drawer .main-navigation {
    width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
    background: transparent !important;
    box-sizing: border-box !important;
}

/* Menu grid */
.ast-mobile-popup-drawer #ast-hf-mobile-menu {
    display: grid !important;
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    gap: 6px !important;
    width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
    list-style: none !important;
    box-sizing: border-box !important;
    background: transparent !important;
}

/* Menu items */
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li {
    display: block !important;
    width: 100% !important;
    min-width: 0 !important;
    max-width: none !important;
    margin: 0 !important;
    padding: 0 !important;
    border: 0 !important;
    box-sizing: border-box !important;
    background: transparent !important;
}

/* Menu links */
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li > a.menu-link {
    display: flex !important;
    align-items: center !important;
    justify-content: flex-start !important;
    width: 100% !important;
    min-width: 0 !important;
    max-width: none !important;
    min-height: 36px !important;
    padding: 8px 9px !important;
    box-sizing: border-box !important;
    background: linear-gradient(to bottom, #303030, #242424) !important;
    border: 1px solid rgba(255,255,255,.10) !important;
    border-radius: 6px !important;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,.05),
        0 1px 3px rgba(0,0,0,.16) !important;
    color: #f3f3f3 !important;
    font-family: Anton, Arial, sans-serif !important;
    font-size: 15px !important;
    font-weight: 400 !important;
    line-height: 1.05 !important;
    letter-spacing: .15px !important;
    text-align: left !important;
    text-decoration: none !important;
    text-transform: none !important;
    white-space: normal !important;
    word-break: normal !important;
}

/* Active item */
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li.current-menu-item > a.menu-link,
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li.current_page_item > a.menu-link,
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li.current-menu-ancestor > a.menu-link {
    background: linear-gradient(to bottom, #a40a0e, #760609) !important;
    border-color: rgba(255,255,255,.18) !important;
    color: #fff !important;
}

/* Hover */
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li > a.menu-link:hover,
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li > a.menu-link:focus {
    background: linear-gradient(to bottom, #3a3a3a, #2b2b2b) !important;
    border-color: rgba(164,10,14,.65) !important;
    color: #fff !important;
}

/* First two items */
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li:nth-child(1) > a.menu-link,
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li:nth-child(2) > a.menu-link {
    background: linear-gradient(to bottom, #3b3b3b, #2d2d2d) !important;
    border-color: rgba(255,255,255,.14) !important;
}

/* Scrollbar */
.ast-mobile-popup-drawer .ast-mobile-popup-inner::-webkit-scrollbar {
    width: 6px !important;
}

.ast-mobile-popup-drawer .ast-mobile-popup-inner::-webkit-scrollbar-track {
    background: #1d1d1d !important;
}

.ast-mobile-popup-drawer .ast-mobile-popup-inner::-webkit-scrollbar-thumb {
    background: #666 !important;
    border-radius: 10px !important;
}

/* Small phones */
@media (max-width: 380px) {
    .ast-mobile-popup-drawer.active .ast-mobile-popup-inner,
    .ast-mobile-popup-drawer .ast-mobile-popup-inner {
        width: 90vw !important;
    }

    .ast-mobile-popup-drawer .ast-mobile-popup-content {
        padding: 8px 8px 20px !important;
    }

    .ast-mobile-popup-drawer #ast-hf-mobile-menu {
        gap: 5px !important;
    }

    .ast-mobile-popup-drawer #ast-hf-mobile-menu > li > a.menu-link {
        min-height: 34px !important;
        padding: 7px 8px !important;
        font-size: 14px !important;
    }
}

/* Highlight News and TOP */
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li:nth-child(1) > a.menu-link,
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li:nth-child(2) > a.menu-link {
    position: relative !important;
    background: linear-gradient(to bottom, #a40a0e, #740609) !important;
    border-color: rgba(255,255,255,.22) !important;
    color: #fff !important;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,.10),
        0 2px 8px rgba(164,10,14,.28) !important;
}

/* Убираем белые палки перед News и TOP */
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li:nth-child(1) > a.menu-link::before,
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li:nth-child(2) > a.menu-link::before {
    content: none !important;
    display: none !important;
}

/* Hover News and TOP */
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li:nth-child(1) > a.menu-link:hover,
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li:nth-child(2) > a.menu-link:hover,
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li:nth-child(1) > a.menu-link:focus,
.ast-mobile-popup-drawer #ast-hf-mobile-menu > li:nth-child(2) > a.menu-link:focus {
    background: linear-gradient(to bottom, #c10d12, #8b070b) !important;
    border-color: rgba(255,255,255,.30) !important;
    color: #fff !important;
}
.lw-emoji-page .lw-emoji-item {
    font-family: "Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji", "Segoe UI Symbol", sans-serif !important;
    font-size: 31px !important;
    line-height: 1 !important;
    color: #111 !important;
    -webkit-text-fill-color: #111 !important;
    text-shadow: none !important;
}

.lw-emoji-page .lw-emoji-item .lw-emoji-symbol {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    position: static !important;
    width: auto !important;
    height: auto !important;
    min-width: 1em !important;
    min-height: 1em !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: visible !important;
    clip: auto !important;
    clip-path: none !important;
    visibility: visible !important;
    opacity: 1 !important;
