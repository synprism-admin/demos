.views-59 ul {
    display: grid !important;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 20px;
    padding: 0;
    margin: 0;
    list-style: none;
}

.views-59 .viewstumb {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;

    text-align: center;
    border: 1px solid #ddd;
    padding: 12px;
    box-sizing: border-box;
}

.views-59 .viewstumb a:first-child {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
	    border: 0px;

}

.views-59 .viewstumb img {
    display: block;
    width: 120px;
    min-width: 120px;
    max-width: 120px;
    height: auto;
    margin: 0 auto 10px;
		padding: 0px;
}

.views-59 .viewstumb a:last-child {
    display: flex;
    align-items: center;
    justify-content: center;

    width: 100%;
    min-height: 42px;
    line-height: 1.3;
    text-align: center;
    text-decoration: none;
}
.views-59 .widget-title {
    background: none !important;
    padding-left: 0 !important;
    margin-left: 0 !important;
    text-align: left;
}
/* планшет */
@media (max-width: 991px) {
    .views-59 ul {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }
}

/* мобильная */
@media (max-width: 600px) {
    .views-59 ul {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 15px;
    }
}

