    background: url(/wp-content/themes/astra/color-wheel/combination_01.svg) no-repeat center center;
}
.box_color_custom .sel_col .combination_01:hover, .box_color_custom .sel_col .combination_01.active {
    background: url(/wp-content/themes/astra/color-wheel/combination_01_h.svg) no-repeat center center;
}
.box_color_custom .sel_col .combination_02 {
    background: url(/wp-content/themes/astra/color-wheel/combination_02.svg) no-repeat center center;
}
.box_color_custom .sel_col .combination_02:hover, .box_color_custom .sel_col .combination_02.active {
    background: url(/wp-content/themes/astra/color-wheel/combination_02_h.svg) no-repeat center center;
}
.box_color_custom .sel_col .combination_03 {
    background: url(/wp-content/themes/astra/color-wheel/combination_03.svg) no-repeat center center;
}
.box_color_custom .sel_col .combination_03:hover, .box_color_custom .sel_col .combination_03.active {
    background: url(/wp-content/themes/astra/color-wheel/combination_03_h.svg) no-repeat center center;
}
.box_color_custom .sel_col .combination_04 {
    background: url(/wp-content/themes/astra/color-wheel/combination_04.svg) no-repeat center center;
}
.box_color_custom .sel_col .combination_04:hover, .box_color_custom .sel_col .combination_04.active {
    background: url(/wp-content/themes/astra/color-wheel/combination_04_h.svg) no-repeat center center;
